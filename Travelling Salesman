n = 4
graph = [
    [0,10,15,20],
    [10,0,35,25],
    [15,35,0,30],
    [20,25,30,0]
]

visited = [False]*n
visited[0] = True

def tsp(pos, count, cost):
    if count == n:
        return cost + graph[pos][0]

    ans = float('inf')

    for i in range(n):
        if not visited[i]:
            visited[i] = True
            ans = min(ans, tsp(i, count+1, cost + graph[pos][i]))
            visited[i] = False

    return ans

print("Minimum cost:", tsp(0,1,0))
