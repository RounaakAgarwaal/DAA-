jobs = [
    ('A', 2, 100),
    ('B', 1, 19),
    ('C', 2, 27),
    ('D', 1, 25),
    ('E', 3, 15)
]

# sort by profit descending
jobs.sort(key=lambda x: x[2], reverse=True)

max_deadline = max(job[1] for job in jobs)
slots = [-1] * max_deadline

for job in jobs:
    for j in range(job[1]-1, -1, -1):
        if slots[j] == -1:
            slots[j] = job[0]
            break

print("Job sequence:", [job for job in slots if job != -1])
